{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "offers.weblith.dev"
        }
      ],
      "destination": "/api/render-site"
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "offers.weblith.dev"
        }
      ],
      "destination": "/api/render-site"
    }
  ]
}